<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.animate-fade').forEach(el => observer.observe(el));

    function openModal() {
    const modal = document.getElementById('playbookModal');
    modal.style.display = 'flex';
    modal.style.alignItems = 'center';
    modal.style.justifyContent = 'center';
    modal.style.flexDirection = 'column';
  }

  function closeModal() {
    document.getElementById('playbookModal').style.display = 'none';
  }

  // EmailJS configuration (fill these with your actual values)
  const EMAILJS_PUBLIC_KEY = '';
  const EMAILJS_SERVICE_ID = '';
  const EMAILJS_TEMPLATE_ID_USER = '';
  const EMAILJS_TEMPLATE_ID_ADMIN = '';
  const ADMIN_EMAIL = '';

  function isEmailJsConfigured() {
    return (
      typeof window !== 'undefined' &&
      window.emailjs &&
      EMAILJS_PUBLIC_KEY &&
      EMAILJS_SERVICE_ID &&
      (EMAILJS_TEMPLATE_ID_USER || EMAILJS_TEMPLATE_ID_ADMIN)
    );
  }

  (function initEmailJsIfNeeded() {
    if (isEmailJsConfigured()) {
      try {
        emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });
      } catch (err) {
        console.warn('EmailJS init failed:', err);
      }
    }
  })();

  async function sendEmailsAfterSubmit(name, email, phone) {
    if (!isEmailJsConfigured()) return;
    const tasks = [];
    if (EMAILJS_TEMPLATE_ID_USER) {
      tasks.push(
        emailjs
          .send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID_USER, {
            to_email: email,
            to_name: name,
            from_name: 'The AWAKE Method',
            phone,
          })
          .catch(err => console.warn('EmailJS user email failed:', err))
      );
    }
    if (EMAILJS_TEMPLATE_ID_ADMIN && ADMIN_EMAIL) {
      tasks.push(
        emailjs
          .send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID_ADMIN, {
            to_email: ADMIN_EMAIL,
            from_name: 'Website Lead',
            name,
            email,
            phone,
          })
          .catch(err => console.warn('EmailJS admin email failed:', err))
      );
    }
    try {
      await Promise.all(tasks);
    } catch (err) {
      // Already logged per-task; no further action needed
    }
  }

  document.getElementById('register-form').addEventListener('submit', function (e) {
    e.preventDefault();

    const name = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const phone = document.getElementById('phone').value.trim();

    if (!name || !email || !phone) {
      alert('Please fill in all fields.');
      return;
    }

    grecaptcha.ready(function () {
      grecaptcha
        .execute('6LfeyJArAAAAACsL8QodlIiLoKzOKtkbeGHvVMxE', { action: 'submit' })
        .then(function (token) {
          const formData = new URLSearchParams();
          formData.append('name', name);
          formData.append('email', email);
          formData.append('phone', phone);
          formData.append('recaptcha_token', token);

          return fetch(
            'https://script.google.com/a/macros/ceciliareinaldo.com/s/AKfycbz29git9jqnbHqGTBldvkF_hphqba4Xv8rxGH71MPrPLlJZSYk7oDexgD2I51l09PH5/exec',
            {
              method: 'POST',
              body: formData,
            }
          )
            .then(res => {
              // Best-effort parse; Apps Script often returns JSON
              try {
                return res.json();
              } catch (_) {
                return null;
              }
            })
            .catch(err => {
              console.error('Submission error:', err);
              return null;
            })
            .finally(() => {
              // Fire-and-forget emails; do not block UI
              sendEmailsAfterSubmit(name, email, phone);

              // Update UI regardless, so users can access the download link
              document.getElementById('register-form').style.display = 'none';
              document.getElementById('form-description').style.display = 'none';
              document.getElementById('download-button').style.display = 'inline-block';
            });
        });
    });
  });

  let scrollIndex = 0;
  function scrollCarousel(direction) {
    const track = document.querySelector('.carousel-track');
    const videoElem = track.querySelector('video');
    const itemWidth = videoElem.offsetWidth + 20; // 20px gap
    const visibleItems = Math.floor(track.parentElement.offsetWidth / itemWidth);
    const maxIndex = track.children.length - visibleItems;
    scrollIndex += direction;
    scrollIndex = Math.max(0, Math.min(scrollIndex, maxIndex));
    track.style.transform = `translateX(-${scrollIndex * itemWidth}px)`;
  }

